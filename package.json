{
  "name": "ai-rate-queue",
  "version": "0.1.0",
  "description": "Redis-backed requests-per-minute limiter for AI/LLM API calls.",
  "license": "MIT",
  "author": "Julian M. Kleber",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cap-jmk-real/ai-rate-queue.git"
  },
  "bugs": {
    "url": "https://github.com/cap-jmk-real/ai-rate-queue/issues"
  },
  "homepage": "https://github.com/cap-jmk-real/ai-rate-queue#readme",
  "keywords": [
    "rate-limit",
    "queue",
    "redis",
    "openai",
    "anthropic",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.include=src/** --coverage.thresholds.branches=100 --coverage.thresholds.functions=100 --coverage.thresholds.lines=100 --coverage.thresholds.statements=100",
    "audit": "npm audit --audit-level=high",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "ci": "npm run test:coverage",
    "version:check": "node scripts/check-version-not-released.mjs",
    "version:patch": "npm version patch -m \"chore: release %s\"",
    "version:minor": "npm version minor -m \"chore: release %s\"",
    "version:major": "npm version major -m \"chore: release %s\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ioredis": "^5.10.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ioredis": "^5.10.0",
    "vitest": "^3.2.4",
    "vitepress": "^1.6.4",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22"
  }
}

